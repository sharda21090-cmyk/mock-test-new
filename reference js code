function callApi(targetURL, method, formData, headers, functionName) {
    var options = {
        "method": method,
        "payload": formData,
        "headers": headers
    }
    try {
        var response = UrlFetchApp.fetch(targetURL, options);
    } catch (error) {
        return false;
    }

    if (typeof response !== undefined && typeof response.token !== undefined)
        if (functionName == "getResult") {
            return response;
        }
        else if (functionName == "loginToLMS") {
            return JSON.parse(response.getContentText()).data;
        }
        else if (functionName == "autoLogin") {
            return JSON.parse(response.getContentText()).data;
        }
        else if (functionName == "addSoln") {
            return response;
        }
        else if (typeof response !== undefined && typeof response.token !== undefined)
            if (functionName == "GetQuesDetails") {
                return response;
            }
            else if (typeof response !== undefined && typeof response.token !== undefined)
                if (functionName == "engHindi") {
                    return response;
                }
                else if (typeof response !== undefined && typeof response.token !== undefined)
                    if (functionName == "getResult1") {
                        return response;
                    }
    if (functionName == "ChatGPT") {
        return response.getContentText()
    }
    else {
        return false;

    }



}
