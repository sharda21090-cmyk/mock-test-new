function loginToLMS() {
    var ui = SpreadsheetApp.getUi();
    var address = 'http://lms-api.testbook.com'
    var lms_sign = address + '/api/v2/admin/login'
    var ui = SpreadsheetApp.getUi();

    var userChoice = ui.alert("Confirm", "Do you want to use any other LMS account?", ui.ButtonSet.YES_NO);
    if (userChoice == ui.Button.YES) {
        var lmsEmail = ui.prompt("Enter email used in LMS", "", ui.ButtonSet.OK_CANCEL);
        var password = ui.prompt("Enter LMS password", "", ui.ButtonSet.OK_CANCEL);
        var otp = ui.prompt("Enter OTP", "", ui.ButtonSet.OK_CANCEL);
        var email = lmsEmail.getResponseText();
        var pass = password.getResponseText();
        var gOTP = otp.getResponseText();
    }

    else {


        var password = ui.prompt("Enter LMS password", "", ui.ButtonSet.OK_CANCEL);
        var otp = ui.prompt("Enter OTP", "", ui.ButtonSet.OK_CANCEL);
        var email = Session.getEffectiveUser().getEmail();
        var pass = password.getResponseText();
        var gOTP = otp.getResponseText();

    }
    var sign_data = {
        'email': email,
        'password': pass,
        'otp': gOTP
    }
    authCode = callApi(lms_sign, "post", sign_data, null, "loginToLMS").token;
    return authCode;
}


