function convertMathAndRemoveHtml5(htmlBlock) {

    htmlBlock = htmlBlock.toString().replace(/&amp;/g, '&')
        .replace(/&lt;/g, '<')
        .replace(/&gt;/g, '>')
        .replace(/&quot;/g, '"')
        .replace(/&#39;/g, '\'')
        .replace(/&nbsp;/g, ' ')
        .replace(/&radic;/g, "√")
        .replace(/~/g, ' ')
        .replace(/&infin;,/g, "∞")
        .replace(/\\theta/g, "θ")
        .replace(/\\left/g, '')
        .replace(/\\right/g, '')
        .replace(/\\cos/g, 'cos')
        .replace(/\\sin/g, 'sin')
        .replace(/\\alpha/g, "α")
        .replace(/\\&deg; /g, "°")
        .replace(/\\begin{array}{[^}]*}/g, '(')
        .replace(/\\end{array}/g, ')')
        .replace(/&lsquo;/g, "'")
        .replace(/&ldquo;/g, '"')
        .replace(/&rdquo;/g, '"')
        .replace(/&rsquo;/g, "'")
        .replace(/&minus;/g, "-")
        .replace(/\\\\/g, '; ')
        .replace(/&prop;/g, '∝')
        .replace(/&deg;/g, 'º')
        .replace(/&ordm;/g, 'º')
        .replace(/&times;/g, '×')
        .replace(/&Delta;/g, "Δ")
        .replace(/&divide;/g, '÷') //∠
        .replace(/&ang;/g, '∠')

    htmlBlock = htmlBlock.replace(/<[^>]+>/g, '');

    // htmlBlock = htmlBlock.replace(/_\\?{?(\d+)}?/g, function (match, p1) {
    //   return digitToSubscript(p1);
    // });


    htmlBlock = htmlBlock.replace(/\\\(/g, '').replace(/\\\)/g, '');


    htmlBlock = htmlBlock.replace(/\\rm\s*/g, '');


    htmlBlock = htmlBlock.replace(/\\frac{([^}]+)}{([^}]+)}/g, "($1)/($2)");

    // htmlBlock = htmlBlock.replace(/<sup>([^<]+)<\/sup>/g, "^($1)");

    // // Handle subscript tags (improved)
    // htmlBlock = htmlBlock.replace(/<sub>([^<]+)<\/sub>/g, "($1)").replace(/<sup>(.*?)<\/sup>/g, "^($1)")
    //   .replace(/<sub>(.*?)<\/sub>/g, "_($1)");



    // Generic superscript and subscript handling
    htmlBlock = htmlBlock.replace(/([^\s\d\-+\*/])\^([^<]+)/g, "$1^($2)");
    htmlBlock = htmlBlock.replace(/([^\s\d\-+\*/])_([^<]+)/g, "$1_($2)");


    htmlBlock = htmlBlock.replace(/\\sqrt{([^}]+)}/g, "√($1)");


    htmlBlock = htmlBlock.replace(/\\sqrt\[3\]{([^}]+)}/g, "∛($1)");


    htmlBlock = htmlBlock.replace(/\^{([^}]+)}/g, "^($1)");

    htmlBlock = htmlBlock.replace(/([^\s\d\-+\*/])_([^<]+)/g, "$1_($2)");


    // const inequalities = {
    //   "\\ge": "≥",
    //   "\\le": "≤",
    //   "\\ne": "≠",
    //   "\\>": ">", // Ensure direct LaTeX symbol replacements
    //   "\\<": "<"
    // };
    // for (const [key, value] of Object.entries(inequalities)) {
    //   htmlBlock = htmlBlock.replace(new RegExp(key, 'g'), value);
    // }


    htmlBlock = htmlBlock.replace(/\\(cos|sin|tan|sec|csc|cot)\{([^}]+)\}/g, "$1($2)");


    const simpleReplacements = {
        "\\\\times": "×",
        "\\\\cdot": "⋅",
        "\\\\div": "÷",
        "\\\\pm": "±",
        "\\\\theta": "θ",
    };

    Object.keys(simpleReplacements).forEach((key) => {
        const re = new RegExp(key, 'g');
        htmlBlock = htmlBlock.replace(re, simpleReplacements[key]);
    });


    htmlBlock = htmlBlock.replace(/\\([^a-zA-Z])/g, "$1")
    htmlBlock = htmlBlock.replace(/(\d+)_{([^<]+)}/g, "($1)_($2)");

    return htmlBlock;
}

