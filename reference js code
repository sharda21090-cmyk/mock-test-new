    var posX = 20;
    var posY = 40;
    var maxWidth = 650;
    var alignment = sheet.getRange('H2').getValue();

    // Assume lightlogo and darklogo are defined somewhere in your script
    var im = (lc == 'Light') ? lightlogo : darklogo;

    var image = DriveApp.getFileById(im);
    slide.insertImage(image, 2, 2, 100, 50);

    var slideWidth = presentation.getPageWidth();

    posX = alignment === "right" ? slideWidth * 0.3 : 20;  // Adjust based on alignment
    posY = 40;
    maxWidth = alignment === "right" ? slideWidth * 0.7 : slideWidth * 0.7;  // Calculate 70% width

    // Add the titlePrefix ("Q" or "Ans") to the beginning of the question text

    if (qno == "Yes") {
        var question = titlePrefix + ". " + rowData[0];
    }
    else {
        var question = rowData[0];
    }
    //var options = rowData.slice(1, 5);
    var correctOptionIndex = rowData[6] - 1; // Adjusting because sheet indices start at 1
    var textContent = question + '\n\n';
    // options.forEach(function (option, index) {
    //   textContent += option + '\n';
    // });

    var op5 = rowData[5]
    Logger.log(op5)
    Logger.log("op5")

    var options = op5 != null ? rowData.slice(1, 6) : rowData.slice(1, 5);
    options.forEach(function (option, index) {
        // If this is the correct option, prepend and append '**' to highlight it
        if (highlightCorrectOption && index == correctOptionIndex) {
            textContent += "**" + option + "**" + '\n';
        } else {
            textContent += option + '\n';
        }
    });

    // Modifications to insertCombinedStyledTexta or its replacement function may be needed
    // Assuming insertCombinedStyledTexta is a custom function handling text styling and insertion
    posY += insertCombinedStyledTexta(slide, textContent, posX, posY, maxWidth, 50, size, fontColor, highlightCorrectOption);
}

function insertCombinedStyledTexta(slide, textContent, posX, posY, width, initialHeight, fontSize, fontColor, highlightCorrectOption) {
    var lines = textContent.split('\n');
    var lineHeight = fontSize * 1.2; // Estimate line height
    var adjustedHeight = lines.length * lineHeight + 20; // Add some padding
    var cleanTextContent = textContent.replace(/^\*\*|\*\*$/gm, ''); // Remove ** markers for insertion

    var textBox = slide.insertTextBox(cleanTextContent, posX, posY, width, adjustedHeight);
    var textStyle = textBox.getText().getTextStyle();
    textStyle.setBold(true);
    textStyle.setFontSize(parseInt(fontSize));
    textStyle.setForegroundColor(fontColor); // Set default color

    Logger.log(crOpColor)

    if (highlightCorrectOption) {
        var currentOffset = 0;
        lines.forEach(function (line) {
            var isCorrectOptionLine = line.startsWith("**");
            if (isCorrectOptionLine) {
                var correctedLine = line.replace(/^\*\*|\*\*$/g, ''); // Remove ** for length calculation
                var start = currentOffset;
                var end = start + correctedLine.length;
                // Apply highlighting to this range
                var range = textBox.getText().getRange(start, end);
                range.getTextStyle().setForegroundColor(crOpColor).setBold(true); // Use a specific color for highlighting
                currentOffset += correctedLine.length + 1; // Adjust offset considering newline
            } else {
                currentOffset += line.length + 1; // Adjust for lines without **
            }
        });
    }

    // Adjust height properly based on content
    return adjustedHeight;
}



